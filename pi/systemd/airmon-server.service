[Unit]
Description=airmon FastAPI server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=umut
Group=umut
WorkingDirectory=/home/umut/airmon-server
Environment=AIRMON_DB_PATH=/home/umut/airmon-data/server.db
ExecStart=/home/umut/airmon-server/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
